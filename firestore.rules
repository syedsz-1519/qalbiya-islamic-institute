rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to fetch user data for admin verification
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation of user profiles on sign up
      allow create: if isOwner(userId) && 
        isValidId(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'enrollments', 'bookmarks', 'progress', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email is string &&
        request.resource.data.displayName is string &&
        request.resource.data.role in ['student', 'admin'] &&
        request.resource.data.enrollments is list &&
        request.resource.data.bookmarks is list &&
        request.resource.data.progress is map;

      // Allow users to update their profile, but block changing their own role/email or modifying immutable fields
      allow update: if (isOwner(userId) && 
        isValidId(userId) &&
        // Secure fields: Role cannot be updated by normal students
        request.resource.data.role == resource.data.role &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // Bounds checking
        (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 100) &&
        (request.resource.data.bookmarks is list && request.resource.data.bookmarks.size() <= 100) &&
        (request.resource.data.enrollments is list && request.resource.data.enrollments.size() <= 100)
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    // Course Form mappings
    match /course_forms/{courseId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/course_forms/$(courseId)));
    }

    // Triggered Welcome Emails
    match /triggered_emails/{emailId} {
      allow read: if isSignedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Student Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true; // Public can see approved testimonials
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Admissions Contact Form Submissions
    match /contact_submissions/{submissionId} {
      allow create: if true; // Public contact form submission
      allow read, update, delete: if isAdmin();
    }

    // WhatsApp Live Inquiry logs
    match /whatsapp_inquiries/{inquiryId} {
      allow create: if true; // Public WhatsApp quick log
      allow read, update, delete: if isAdmin();
    }

    // Course FAQs Collection Rules
    match /faqs/{faqId} {
      allow read: if true; // Public can see FAQs
      allow write: if isAdmin(); // Only admins can add, update, or delete FAQs
    }
  }
}
